---
import { site } from '../data/site';
import { Image } from 'astro:assets';
import heroPhoto from '../assets/fahad.jpg';
---

<section id="top" class="hero section">
  <div class="container hero__grid">
    <div class="hero__body">
      <p class="hero__eyebrow">{site.role} · {site.location}</p>
      <h1 class="hero__title">
        I turn hard problems into
        <span class="hero__accent">software that ships.</span>
      </h1>
      <p class="hero__lead">
        I'm {site.name.split(' ')[0]} — a software engineer at heart. I build and ship
        real products end to end — mobile apps, the backends behind them, and the
        business systems they connect to — usually owning the hard parts that tie
        everything together. What sets me apart is my work in
        <strong>AI-native engineering</strong>: smarter, more automated ways for
        teams to turn an idea into working software, faster and with fewer mistakes.
      </p>
      <div class="hero__actions">
        <a class="btn btn--primary" href="#contact">Contact me</a>
        {/*
          Rendered as a button, not a direct file link, so PDF browser
          extensions (e.g. pdfFiller) don't inject an "Open with…" overlay.
          The download is triggered by the script below.
        */}
        <button
          class="btn btn--ghost"
          type="button"
          id="resume-download"
          data-resume={site.cvPath.replace(/\.pdf$/i, '')}
        >
          Download Resume
        </button>
      </div>
    </div>

    <div class="hero__aside">
      <Image
        class="hero__photo"
        src={heroPhoto}
        alt={`Portrait of ${site.name}`}
        widths={[220, 300, 560]}
        sizes="(max-width: 820px) 200px, 280px"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(3rem, 7vw, 5rem);
    padding-bottom: clamp(1.5rem, 4vw, 2.5rem);
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    /* subtle accent glow behind the hero */
    content: '';
    position: absolute;
    inset: -30% 40% auto -10%;
    height: 60%;
    background: radial-gradient(
      50% 50% at 50% 50%,
      var(--accent-dim),
      transparent 70%
    );
    filter: blur(20px);
    pointer-events: none;
    z-index: 0;
  }
  .hero__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.7fr 0.8fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .hero__aside {
    max-width: 280px;
    justify-self: end;
    width: 100%;
  }
  .hero__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent);
    margin: 0 0 1rem;
    letter-spacing: 0.02em;
  }
  .hero__title {
    margin-bottom: 1.25rem;
  }
  .hero__accent {
    color: var(--accent-strong);
  }
  .hero__lead {
    color: var(--text-muted);
    font-size: 1.08rem;
    max-width: 54ch;
  }
  .hero__lead strong {
    color: var(--text);
    font-weight: 600;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.75rem;
  }

  .hero__photo {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: var(--radius);
    border: 1px solid var(--border-strong);
    box-shadow: var(--shadow);
  }

  @media (max-width: 820px) {
    .hero__grid {
      grid-template-columns: 1fr;
    }
    .hero__aside {
      order: -1;
      max-width: 200px;
      justify-self: start;
    }
  }
</style>

<script>
  // Trigger the resume download programmatically so no persistent `.pdf`
  // anchor exists in the DOM for PDF extensions to attach an overlay to.
  const btn = document.getElementById('resume-download');
  btn?.addEventListener('click', () => {
    const base = btn.dataset.resume;
    if (!base) return;
    // Extension is re-attached here so the literal never appears in the DOM.
    const a = document.createElement('a');
    a.href = base + '.pdf';
    a.download = 'Fahad-Ahmad-Siddiqui-Resume.pdf';
    document.body.appendChild(a);
    a.click();
    a.remove();
  });
</script>
