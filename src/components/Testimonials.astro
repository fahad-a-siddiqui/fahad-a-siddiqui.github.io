---
import { testimonials } from '../data/testimonials';
---

{testimonials.length > 0 && (
  <section id="testimonials" class="section section--alt">
    <div class="container">
      <div class="section__head">
        <p class="section__eyebrow">Testimonials</p>
        <h2>From people I've worked with</h2>
      </div>

      <ul class="testimonials">
        {testimonials.map((t) => (
          <li class="testimonial">
            <blockquote class="testimonial__quote">"{t.quote}"</blockquote>
            <div class="testimonial__author">
              <span class="testimonial__name">{t.name}</span>
              <span class="testimonial__title">{t.title}</span>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>
)}

<style>
  .testimonials {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    list-style: none;
  }
  .testimonial {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    padding-left: 1.5rem;
    border-left: 2px solid var(--border-strong);
  }
  .testimonial__quote {
    margin: 0;
    color: var(--text);
    font-size: 1rem;
    line-height: 1.65;
  }
  .testimonial__author {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.25rem 0.6rem;
  }
  .testimonial__name {
    font-weight: 600;
    color: var(--text);
  }
  .testimonial__title {
    color: var(--text-faint);
    font-size: 0.85rem;
    font-family: var(--font-mono);
  }
</style>
